<Window x:Class="SSHEasyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:terminal="clr-namespace:SSHEasyApp.Terminal"
        Title="SSH Easy" Height="600" Width="900"
        Background="{StaticResource BgDeep}"
        Foreground="{StaticResource FgDefault}"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BgSurface}" 
                BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Sidebar Header -->
                <StackPanel Grid.Row="0" Margin="16,20,16,10">
                    <TextBlock Text="Connections" FontSize="18" FontWeight="SemiBold" 
                               Foreground="{StaticResource FgDefault}"/>
                </StackPanel>
                
                <!-- Profiles List -->
                <ListBox x:Name="ProfilesList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Margin="8,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Style="{StaticResource ProfileListItem}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                               Foreground="{StaticResource FgDefault}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Host}" FontSize="12"
                                                               Foreground="{StaticResource FgMuted}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <!-- Action Buttons (visible on hover) -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                                            x:Name="ActionPanel" Visibility="Hidden">
 
                                                    <Button Content="✎" Style="{StaticResource IconButton}" 
                                                            Click="EditProfile_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                    <Button Content="✕" Style="{StaticResource IconButton}" 
                                                            Click="DeleteProfile_Click" Tag="{Binding Id}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ActionPanel" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                
                <!-- Add Button -->
                <Button Grid.Row="2" Content="+ New Connection" Style="{StaticResource PrimaryButton}"
                        Margin="16,10,16,20" Click="AddProfile_Click"/>
            </Grid>
        </Border>
        
        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" 
                      Background="{StaticResource BorderSubtle}"/>
        
        <!-- Main Area (Terminal) -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}" 
                    BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource FgMuted}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusText" Text="Not Connected" FontWeight="SemiBold" 
                                   Foreground="{StaticResource FgDefault}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionInfoText" Text="" Margin="8,0,0,0"
                                   Foreground="{StaticResource FgMuted}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="RdpButton" Content="Start RDP" 
                                Background="{StaticResource Accent}" Foreground="White" BorderThickness="0" Padding="12,6"
                                Visibility="Collapsed" Margin="0,0,8,0" Cursor="Hand"
                                Click="RdpButton_Click"/>
                        <Button x:Name="RebootButton" Content="Reboot" 
                                Style="{StaticResource DangerButton}" Visibility="Collapsed" Margin="0,0,8,0"
                                Click="Reboot_Click"/>
                        <Button x:Name="ShutdownButton" Content="Shutdown" 
                                Style="{StaticResource DangerButton}" Visibility="Collapsed" Margin="0,0,8,0"
                                Click="Shutdown_Click"/>
                        <Button x:Name="DisconnectButton" Content="Disconnect" 
                                Style="{StaticResource DangerButton}" Visibility="Collapsed"
                                Click="Disconnect_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Terminal Host -->
            <Border Grid.Row="1" Background="{StaticResource BgDeep}">
                <Grid>
                    <!-- Empty state -->
                    <Grid x:Name="EmptyStatePanel">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="SSH Easy" FontSize="32" FontWeight="SemiBold" 
                                       Foreground="{StaticResource FgSubtle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a connection from the sidebar to begin" 
                                       Foreground="{StaticResource FgMuted}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- The actual terminal control -->
                    <terminal:TerminalControl x:Name="Terminal" Visibility="Collapsed" Margin="4"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
